{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Duckle",
  "version": "0.4.2",
  "identifier": "io.duckle.app",
    "build": {
    "beforeDevCommand": "npm --prefix ../frontend run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm --prefix ../frontend run build",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Duckle",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "fullscreen": false,
        "maximized": true,
        "visible": false,
        "backgroundColor": "#07090F",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "resources": [],
    "targets": [],
    "category": "DeveloperTool",
    "shortDescription": "Embedded, ultra-fast data engineering platform.",
    "longDescription": "Duckle is an open-source, local-first ETL/ELT/streaming platform with a drag-and-drop UI and native execution speed.",
    "copyright": "Copyright 2026 Sourav Roy",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
